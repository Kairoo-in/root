# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# ─── Required ─────────────────────────────────────────────────────────────────
# Primary Gemini key (free tier via Google AI Studio).
GEMINI_API_KEY=

# ─── Optional LLM provider keys (Phase 2A — all free tiers) ───────────────────
# Leave blank to skip that provider; the gateway falls through to the next tier.

GROQ_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_WRITE_TOKEN=
OLLAMA_API_KEY=

# Comma-separated provider priority list, controls fallback order.
# Default (when unset): gemini first, then the order in registry.config.ts.
# AI_PROVIDER_PRIORITY=gemini,cerebras,groq,nvidia,openrouter,huggingface,ollama

# Note: CLOD_API_KEY / AI_NATIVE_API_KEY can be added to
# engines/ai/providers/registry.config.ts once their base URLs are confirmed.
# ─────────────────────────────────────────────────────────────────────────────
